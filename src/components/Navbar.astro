---
interface Props {
  phone: string;
  phoneHref: string;
}

const { phone, phoneHref } = Astro.props;
const links = [
  ['hero', 'Úvod'],
  ['specialties', 'O nás'],
  ['process', 'Jak pracujeme'],
  ['services', 'Služby'],
  ['inquiry', 'Kontakt'],
];
---

<nav id="main-navbar" class="fixed left-0 right-0 top-0 z-50 bg-transparent px-4 py-4 transition-all duration-300 ease-in-out md:py-3 lg:px-6">
  <div class="mx-auto flex max-w-7xl items-center justify-between">
    <a href="/#hero" class="flex-shrink-0" aria-label="Mystic Garden">
      <img src="/images/logo.svg" alt="Mystic Garden Logo" class="h-10 md:h-12 lg:h-[65px]" width="166" height="65" />
    </a>

    <div class="nav-links hidden items-center space-x-1.5 md:flex lg:space-x-8">
      {links.map(([id, label]) => (
        <a href={`/#${id}`} class="nav-link whitespace-nowrap px-2 py-1.5 text-sm text-mystic transition-colors duration-200 hover:text-white md:text-base lg:px-3" data-scroll data-scroll-target={id}>
          {label}
        </a>
      ))}
    </div>

    <div class="hidden flex-shrink-0 md:block">
      <a href={phoneHref} class="inline-flex items-center justify-center rounded-md bg-mystic px-3 py-1.5 text-sm font-semibold text-green-950 transition-colors duration-200 hover:bg-mystic-light md:text-base lg:px-4 lg:py-2">
        {phone}
      </a>
    </div>

    <button id="mobile-menu-button" class="text-white md:hidden" type="button" aria-label="Toggle mobile menu">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>
  </div>

  <div id="mobile-menu" class="absolute left-0 right-0 top-full hidden bg-black/60 px-6 py-4 shadow-lg backdrop-blur-md md:hidden">
    <div class="flex flex-col space-y-4">
      {links.map(([id, label]) => (
        <a href={`/#${id}`} class="nav-link rounded-md px-3 py-2 text-mystic transition-colors duration-200 hover:text-white" data-scroll data-scroll-target={id}>
          {label}
        </a>
      ))}
      <a href={phoneHref} class="mt-4 inline-flex items-center justify-center rounded-md bg-mystic px-4 py-2 font-semibold text-green-950 transition-colors duration-200 hover:bg-mystic-light">
        {phone}
      </a>
    </div>
  </div>
</nav>
