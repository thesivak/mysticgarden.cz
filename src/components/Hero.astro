---
interface Props {
  hero: {
    titleLine1: string;
    titleLine2: string;
    subtitle: string;
    cta: string;
    backgroundImage: string;
  };
}

const { hero } = Astro.props;
---

<section id="hero" class="relative h-screen overflow-hidden">
  <div
    class="absolute inset-0 z-0 bg-cover bg-center blur-[3px] transition-transform duration-[10000ms] ease-in-out hover:scale-105"
    style={`background-image: url('${hero.backgroundImage}');`}
    aria-hidden="true"
  ></div>
  <div class="absolute inset-0 z-0 bg-black/50" aria-hidden="true"></div>

  <div class="relative z-10 flex h-full flex-col items-center justify-center px-4 text-center sm:px-6 md:px-8">
    <h1 class="mb-4 text-4xl font-bold leading-tight text-mystic sm:mb-6 sm:text-5xl md:text-6xl">
      <span class="block" data-aos="fade-down">{hero.titleLine1}</span>
      <span class="mt-2 block" data-aos="fade-up">{hero.titleLine2}</span>
    </h1>

    <p class="mx-auto mb-6 max-w-3xl text-base leading-relaxed text-white sm:mb-8 sm:text-lg" data-aos="fade-up">
      {hero.subtitle}
    </p>

    <div class="mt-2 flex w-full flex-col gap-3 sm:mt-4 sm:w-auto sm:flex-row sm:gap-4" data-aos="zoom-in">
      <a href="#inquiry" class="inline-flex w-full items-center justify-center rounded-md bg-mystic px-8 py-3 text-lg font-semibold text-green-950 transition-colors duration-200 hover:bg-mystic-light sm:w-auto">
        {hero.cta}
      </a>
    </div>
  </div>
</section>
