---
interface Post {
  id: string;
  data: {
    title: string;
    excerpt: string;
    publishedAt: Date;
    featuredImage?: string;
    featuredImageAlt?: string;
  };
}

interface Props {
  posts: Post[];
}

const { posts } = Astro.props;
---

{posts.length > 0 && (
  <section id="blog" class="bg-white py-20">
    <div class="mx-auto max-w-7xl px-6">
      <h2 class="mb-12 text-center text-4xl font-semibold text-green-950">Blog</h2>
      <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
        {posts.map((post) => (
          <article class="overflow-hidden rounded-lg bg-white shadow-lg">
            {post.data.featuredImage && (
              <img
                src={post.data.featuredImage}
                alt={post.data.featuredImageAlt ?? post.data.title}
                class="aspect-[4/3] w-full object-cover"
                loading="lazy"
              />
            )}
            <div class="p-6">
              <p class="mb-2 text-sm text-gray-500">
                {post.data.publishedAt.toLocaleDateString('cs-CZ')}
              </p>
              <h3 class="text-2xl font-semibold text-gray-900">{post.data.title}</h3>
              <p class="mt-3 text-sm text-gray-600">{post.data.excerpt}</p>
              <a href={`/blog/${post.id}/`} class="mt-5 inline-flex font-semibold text-mystic-secondary hover:text-mystic-secondary-light">
                Číst článek
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
)}
