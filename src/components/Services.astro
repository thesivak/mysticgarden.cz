---
interface Service {
  data: {
    title: string;
    description: string;
    image: string;
    imageAlt: string;
  };
}

interface Props {
  heading: string;
  services: Service[];
}

const { heading, services } = Astro.props;
---

<section id="services" class="relative w-full py-24">
  <h2 class="text-center text-4xl font-semibold md:text-5xl">{heading}</h2>
  <div class="servicesSwiper swiper mt-12">
    <div class="swiper-wrapper">
      {services.map((service) => (
        <div class="swiper-slide">
          <div class="overflow-hidden rounded-lg bg-white">
            <img src={service.data.image} alt={service.data.imageAlt} class="aspect-[4/3] w-full rounded-lg object-cover" loading="lazy" />
            <div class="p-6">
              <h3 class="text-2xl font-semibold text-gray-900">{service.data.title}</h3>
              <p class="mt-3 text-sm text-gray-500">{service.data.description}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
    <div class="swiper-pagination"></div>
  </div>
</section>

<script>
  import Swiper from 'swiper';
  import { Autoplay, Pagination } from 'swiper/modules';
  import 'swiper/css';
  import 'swiper/css/pagination';

  document.addEventListener('DOMContentLoaded', () => {
    new Swiper('.servicesSwiper', {
      modules: [Autoplay, Pagination],
      slidesPerView: 3,
      spaceBetween: 20,
      centeredSlides: true,
      loop: false,
      rewind: true,
      autoplay: {
        delay: 3000,
        disableOnInteraction: false,
      },
      pagination: {
        el: '.swiper-pagination',
        clickable: true,
      },
      breakpoints: {
        320: { slidesPerView: 1, spaceBetween: 20 },
        768: { slidesPerView: 2.5, spaceBetween: 25 },
        1024: { slidesPerView: 3.5, spaceBetween: 30 },
      },
    });
  });
</script>
